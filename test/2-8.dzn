N_TRAINS=3;
TRAINS=[(2,1,RIGHT),(4,3,TOP),(2,6,LEFT)];

N_INIT_POS=8;
INIT_POS=[
  (2,1,STRAIGHT_RL),
  (4,3,STRAIGHT_TD),
  (2,6,STRAIGHT_RL),
  (6,6,STRAIGHT_RL),
  (6,5,STRAIGHT_RL),
  (6,4,STRAIGHT_RL),
  (6,3,STRAIGHT_RL),
  (6,2,STRAIGHT_RL),
];

N_TUNNELS=1;
TUNNEL_PAIRS=[
  (2, 3, RIGHT, 6, 1, RIGHT),  % Tunnel entrance at (2,3), exit at (6,1), both exit RIGHT
];

N_GATES=0;
GATES=[];
N_ACTIVATIONS=0;
ACTIVATIONS=[];

N_DSWITCHES=0;
DSWITCHES=[];
