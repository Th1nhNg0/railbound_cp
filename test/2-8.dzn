% ============================================================
% Puzzle 2-8: Three trains with tunnel teleportation
% ============================================================
% Challenge: Route three trains through a tunnel to reach the target
% Features: TUNNEL_R with directional entry restriction (from RIGHT only)
% ============================================================

W=6;
H=6;

