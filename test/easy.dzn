% ============================================================
% Easy Puzzle: Single train navigation
% ============================================================
% A simple puzzle to test basic track placement
% Single train must navigate from bottom-left to top-right
% ============================================================

W=6;
H=3;

MAX_TIME=W*H;
MAX_TRACKS=10;  

TARGET_R=1;
TARGET_C=6;

N_TRAINS=1;
TRAINS=[(3,1,TOP)];

N_INIT_POS=8;
INIT_POS=[
  (3,1,STRAIGHT_TD),
  (1,6,STRAIGHT_RL),
  (3,2,EMPTY),
  (2,2,EMPTY),
  (1,4,EMPTY),
  (2,4,EMPTY),
  (2,6,EMPTY),
  (3,6,EMPTY),
];

N_TUNNELS=0;
TUNNEL_PAIRS=[];